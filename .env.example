# Copy this file to .env and set backend URLs.
# Legacy fallback (used when *_NOVA / *_GEMINI are missing):
# HABLA_BACKEND_URL=https://your-habla-core-domain.example.com

# Nova 2 Sonic backend (../habla-core)
HABLA_BACKEND_URL_NOVA=https://your-habla-core-domain.example.com

# Gemini backend (../habla-core-gemini)
HABLA_BACKEND_URL_GEMINI=https://your-habla-core-gemini-domain.example.com

# Optional: force default backend selected at build time.
# If omitted, Gemini URL is used when set, otherwise Nova URL.
# HABLA_BACKEND_URL_DEFAULT=https://your-default-backend-domain.example.com

# Optional: enable backend request auth token generation in CI/local config generation.
HABLA_SECRET=
HABLA_APP_BUNDLE_ID=com.maximbilan.habla-ios
